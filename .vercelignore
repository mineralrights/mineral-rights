# They are deployed separately to Cloud Run
api/
*.py
!web/**/*.py

# Python dependencies and config
pyproject.toml
requirements.txt
requirements-*.txt
uv.lock

# Large data directories
data/
demo_tests/
evaluation_results/
test_results/
results/
deed_tracking/
test_imports/
test_tracking/
visualization_output/
visualisation_output/

# Test files
test_*.py
*_test.py
test_*.txt
test_*.js
test_*.csv

# Documentation and examples
docs/
*.md
!README.md
!web/README.md

# Build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# IDE and OS files
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp
*.temp
temp/
tmp/

